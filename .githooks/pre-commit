#!/bin/bash
# Pre-commit hook: runs the same fmt + clippy checks as .gitlab-ci.yml lint stage.
# Skipped when no Rust sources are staged.
#
# Install (run once per clone): git config core.hooksPath .githooks
# Bypass (one-off): git commit --no-verify

set -e

if ! git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.rs$|(^|/)Cargo\.(toml|lock)$'; then
    exit 0
fi

echo "=== pre-commit: cargo fmt --check ==="
cargo fmt --all -- --check || {
    echo
    echo "Format check failed. Run: cargo fmt --all"
    exit 1
}

echo "=== pre-commit: cargo clippy ==="
cargo clippy --workspace --all-targets -- -D warnings || {
    echo
    echo "Clippy failed. Fix the warnings above."
    exit 1
}

echo "pre-commit: passed."
